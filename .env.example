# VLJ HRMS — Environment Configuration
# Copy this file to .env and fill in your values.

# MySQL connection string for Prisma
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:your_password@localhost:3306/vlj_hrms"

# JWT (required for auth)
JWT_SECRET="your-jwt-secret-key"
JWT_EXPIRES_IN="7d"

# Cloudinary — free image/document storage (https://cloudinary.com/users/register/free)
# Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"