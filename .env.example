# VLJ HRMS — Environment Configuration
# Copy this file to .env and fill in your values.

# MySQL connection string for Prisma
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Synology Docker (mysql-hrms container, port 3306 published to host):
# Use 127.0.0.1 when the app runs directly on NAS (npm run dev / npm start)
DATABASE_URL="mysql://vnas:your_password@127.0.0.1:3306/vlj_hrms"
#
# If the Next.js app runs inside Docker on the same network as mysql-hrms:
# DATABASE_URL="mysql://vnas:your_password@mysql-hrms:3306/vlj_hrms"
#
# Root user (encode @ in password): Root@123 → Root%40123
# DATABASE_URL="mysql://root:Root%40123@127.0.0.1:3306/vlj_hrms"

# JWT (required for auth)
JWT_SECRET="your-jwt-secret-key"
JWT_EXPIRES_IN="7d"

# Cloudinary — free image/document storage (https://cloudinary.com/users/register/free)
# Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Public app URL (used in password reset links)
APP_URL="https://hrms.varlakshmijewellery.co.in"

# Gmail SMTP — password reset emails
# Use a Google App Password (not your normal Gmail password):
# Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="varlakshmijewellery@gmail.com"
SMTP_PASS="your_gmail_app_password"
SMTP_FROM="VLJ HRMS <varlakshmijewellery@gmail.com>"